{
  "name": "@jalik/observer",
  "version": "2.2.2",
  "description": "A library to observe events and trigger callbacks.",
  "license": "MIT",
  "keywords": [
    "event",
    "observer",
    "listener"
  ],
  "author": {
    "name": "Karl Stein",
    "email": "karl.stein.pro@gmail.com",
    "url": "https://github.com/jalik"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jalik/js-observer.git"
  },
  "bugs": {
    "url": "https://github.com/jalik/js-observer/issues"
  },
  "sideEffects": false,
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "files": [
    "cjs/",
    "esm/",
    "LICENSE.txt",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && npm run build-cjs && npm run build-esm",
    "build-cjs": "tsc -p tsconfig.cjs.json",
    "build-esm": "tsc",
    "clean": "rimraf ./cjs ./esm",
    "dev-cjs": "tsc --watch -p tsconfig.cjs.json",
    "dev-esm": "tsc --watch",
    "dev": "concurrently 'npm:dev-*'",
    "lint": "eslint",
    "lint-fix": "eslint -fix",
    "prepare": "npm run clean && npm run build",
    "prepublishOnly": "npm run lint && npm test",
    "preversion": "npm run prepublishOnly",
    "test": "vitest run --passWithNoTests --coverage"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
